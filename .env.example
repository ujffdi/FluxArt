# Local mock mode is the default. Copy this file to .env.local and replace
# placeholders before running production mode.

FLUXART_DATA_MODE=mock
IMAGE_MODEL_EXECUTION=mock
IMAGE_MODEL_PROVIDER=agnes
IMAGE_MODEL_NAME=agnes-image-2.1-flash
IMAGE_MODEL_BASE_URL=https://apihub.agnes-ai.com/v1
IMAGE_MODEL_API_KEY_SECRET_REF=FLUXART_IMAGE_API_KEY

# Required for FLUXART_DATA_MODE=prisma or NODE_ENV=production.
DATABASE_URL=mysql://fluxart_user:replace-password@127.0.0.1:3306/fluxart
FLUXART_SESSION_SECRET=replace-with-at-least-32-random-characters

# Required for live image generation.
FLUXART_IMAGE_API_KEY=replace-with-server-only-agnes-key

# Required for production object storage.
MINIO_ENDPOINT=https://minio.example.com
MINIO_PUBLIC_BASE_URL=https://cdn.example.com/fluxart
MINIO_BUCKET=fluxart-assets
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key

# Required for production MaPay payments.
MAPAY_API_URL=https://mzf.mapay.cc
MAPAY_MERCHANT_ID=replace-with-merchant-id
MAPAY_SIGNING_SECRET=replace-with-mapay-signing-secret
MAPAY_NOTIFY_URL=https://app.example.com/api/payments/mapay/notify
MAPAY_RETURN_URL=https://app.example.com/workspace/billing

# Optional when running behind a trusted reverse proxy.
FLUXART_TRUST_PROXY_HEADERS=0
