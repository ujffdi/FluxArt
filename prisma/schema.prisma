generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
}

enum MemberStatus {
  free
  credit_pack
  pro_trial
  pro
}

enum CreditSourceType {
  registration
  daily_free
  purchased
  membership
  adjustment
}

enum CreditType {
  promotional
  purchased
}

enum CreditLedgerEntryType {
  grant
  hold
  spend
  refund
  release
  adjustment
}

enum CreditHoldStatus {
  active
  spent
  released
  refunded
  expired
}

enum OrderStatus {
  pending_payment
  paid
  failed
  refunded
}

enum FulfillmentStatus {
  pending
  fulfilled
  failed
  retryable
}

enum ImageTaskState {
  queued
  running
  storing
  reviewing
  succeeded
  failed
  refunded
}

enum GenerationMode {
  t2i
  i2i
  inpaint
  outpaint
}

enum ProviderMode {
  sync
  async
}

enum ProviderResultStatus {
  pending
  succeeded
  failed
}

enum OutputReviewStatus {
  pending
  approved
  rejected
  skipped
}

enum UploadKind {
  source
  mask
}

enum UploadValidationStatus {
  accepted
  rejected
}

enum DownloadType {
  standard_watermarked
  hd_no_watermark
}

model User {
  id               String            @id @default(cuid()) @db.VarChar(191)
  displayName      String            @map("display_name") @db.VarChar(120)
  status           UserStatus        @default(active)
  memberStatus     MemberStatus      @default(free) @map("member_status")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  credential       UserCredential?
  sessions         UserSession[]
  creditBuckets    CreditBucket[]
  ledgerEntries    CreditLedgerEntry[]
  creditHolds      CreditHold[]
  orders           Order[]
  uploads          ImageUpload[]
  tasks            ImageTask[]
  assets           ImageAsset[]
  downloads        DownloadEvent[]
  membershipCycles MembershipCycle[]

  @@map("users")
}

model UserCredential {
  id                String   @id @default(cuid()) @db.VarChar(191)
  userId            String   @unique @map("user_id") @db.VarChar(191)
  username          String   @unique @db.VarChar(64)
  passwordHash      String   @map("password_hash") @db.VarChar(255)
  hashVersion       String   @default("scrypt-v1") @map("hash_version") @db.VarChar(32)
  passwordChangedAt DateTime @default(now()) @map("password_changed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id])

  @@map("user_credentials")
}

model UserSession {
  id             String    @id @default(cuid()) @db.VarChar(191)
  userId         String    @map("user_id") @db.VarChar(191)
  tokenHash      String    @unique @map("token_hash") @db.VarChar(128)
  slidingExpires DateTime  @map("sliding_expires")
  absoluteExpires DateTime @map("absolute_expires")
  revokedAt      DateTime? @map("revoked_at")
  userAgent      String?   @map("user_agent") @db.VarChar(255)
  ipAddress      String?   @map("ip_address") @db.VarChar(80)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt, slidingExpires])
  @@map("user_sessions")
}

model AuthRateLimitBucket {
  id        String   @id @default(cuid()) @db.VarChar(191)
  scope     String   @unique @db.VarChar(191)
  count     Int
  resetAt   DateTime @map("reset_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("auth_rate_limit_buckets")
}

model CreditBucket {
  id                String           @id @default(cuid()) @db.VarChar(191)
  userId            String           @map("user_id") @db.VarChar(191)
  sourceType        CreditSourceType @map("source_type")
  creditType        CreditType       @map("credit_type")
  originalAmount    Int              @map("original_amount")
  remainingAmount   Int              @map("remaining_amount")
  validFrom         DateTime         @map("valid_from")
  validUntil        DateTime?        @map("valid_until")
  priority          Int
  sourceOrderId     String?          @map("source_order_id") @db.VarChar(191)
  membershipCycleId String?          @map("membership_cycle_id") @db.VarChar(191)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  user              User             @relation(fields: [userId], references: [id])
  sourceOrder       Order?           @relation(fields: [sourceOrderId], references: [id])
  membershipCycle   MembershipCycle? @relation(fields: [membershipCycleId], references: [id])
  ledgerEntries     CreditLedgerEntry[]

  @@index([userId, priority, validUntil])
  @@map("credit_buckets")
}

model CreditLedgerEntry {
  id              String                @id @default(cuid()) @db.VarChar(191)
  userId          String                @map("user_id") @db.VarChar(191)
  bucketId        String?               @map("bucket_id") @db.VarChar(191)
  holdId          String?               @map("hold_id") @db.VarChar(191)
  entryType       CreditLedgerEntryType @map("entry_type")
  amount          Int
  balanceAfter    Int                   @map("balance_after")
  sourceRefType   String                @map("source_ref_type") @db.VarChar(64)
  sourceRefId     String?               @map("source_ref_id") @db.VarChar(191)
  label           String                @db.VarChar(160)
  createdAt       DateTime              @default(now()) @map("created_at")
  user            User                  @relation(fields: [userId], references: [id])
  bucket          CreditBucket?         @relation(fields: [bucketId], references: [id])
  hold            CreditHold?           @relation(fields: [holdId], references: [id])

  @@index([userId, createdAt])
  @@map("credit_ledger_entries")
}

model CreditHold {
  id          String           @id @default(cuid()) @db.VarChar(191)
  userId      String           @map("user_id") @db.VarChar(191)
  amount      Int
  status      CreditHoldStatus @default(active)
  taskId      String?          @map("task_id") @db.VarChar(191)
  downloadId  String?          @unique @map("download_id") @db.VarChar(191)
  expiresAt   DateTime         @map("expires_at")
  convertedAt DateTime?        @map("converted_at")
  refundedAt  DateTime?        @map("refunded_at")
  releasedAt  DateTime?        @map("released_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  user        User             @relation(fields: [userId], references: [id])
  activeTask  ImageTask?       @relation("TaskActiveHold")
  download    DownloadEvent?   @relation("DownloadHoldTarget", fields: [downloadId], references: [id])
  entries     CreditLedgerEntry[]

  @@index([userId, status, expiresAt])
  @@map("credit_holds")
}

model CreditPackSku {
  id           String   @id @default(cuid()) @db.VarChar(191)
  code         String   @unique @db.VarChar(64)
  displayName  String   @map("display_name") @db.VarChar(120)
  creditAmount Int      @map("credit_amount")
  priceCents   Int      @map("price_cents")
  currency     String   @default("CNY") @db.VarChar(8)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("credit_pack_skus")
}

model MembershipPlan {
  id                 String   @id @default(cuid()) @db.VarChar(191)
  code               String   @unique @db.VarChar(64)
  displayName        String   @map("display_name") @db.VarChar(120)
  monthlyPriceCents  Int      @map("monthly_price_cents")
  monthlyCreditGrant Int      @map("monthly_credit_grant")
  hdFairUseCap       Int      @map("hd_fair_use_cap")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  cycles             MembershipCycle[]

  @@map("membership_plans")
}

model MembershipCycle {
  id           String      @id @default(cuid()) @db.VarChar(191)
  userId       String      @map("user_id") @db.VarChar(191)
  planId       String      @map("plan_id") @db.VarChar(191)
  orderId      String?     @map("order_id") @db.VarChar(191)
  cycleStart   DateTime    @map("cycle_start")
  cycleEnd     DateTime    @map("cycle_end")
  status       String      @default("active") @db.VarChar(32)
  hdDownloadsUsed Int      @default(0) @map("hd_downloads_used")
  hdFairUseCap    Int      @default(300) @map("hd_fair_use_cap")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  user         User        @relation(fields: [userId], references: [id])
  plan         MembershipPlan @relation(fields: [planId], references: [id])
  order        Order?      @relation(fields: [orderId], references: [id])
  buckets      CreditBucket[]

  @@index([userId, cycleEnd])
  @@map("membership_cycles")
}

model Order {
  id                 String            @id @default(cuid()) @db.VarChar(191)
  userId             String            @map("user_id") @db.VarChar(191)
  planId             String            @map("plan_id") @db.VarChar(64)
  amountCents        Int               @map("amount_cents")
  currency           String            @default("CNY") @db.VarChar(8)
  provider           String            @default("epay") @db.VarChar(32)
  outTradeNo         String            @unique @map("out_trade_no") @db.VarChar(96)
  status             OrderStatus       @default(pending_payment)
  fulfillmentStatus  FulfillmentStatus @default(pending) @map("fulfillment_status")
  paymentUrl         String?           @map("payment_url") @db.VarChar(512)
  paidAt             DateTime?         @map("paid_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  user               User              @relation(fields: [userId], references: [id])
  buckets            CreditBucket[]
  membershipCycles   MembershipCycle[]
  notifications      PaymentNotification[]

  @@map("orders")
}

model PaymentNotification {
  id                 String   @id @default(cuid()) @db.VarChar(191)
  orderId            String   @map("order_id") @db.VarChar(191)
  providerTradeNo    String?  @map("provider_trade_no") @db.VarChar(128)
  verified           Boolean  @default(false)
  rawPayloadDigest   String   @map("raw_payload_digest") @db.VarChar(128)
  failureReason      String?  @map("failure_reason") @db.VarChar(255)
  receivedAt         DateTime @default(now()) @map("received_at")
  processedAt        DateTime? @map("processed_at")
  order              Order    @relation(fields: [orderId], references: [id])

  @@unique([orderId, rawPayloadDigest])
  @@map("payment_notifications")
}

model ImageUpload {
  id               String                 @id @default(cuid()) @db.VarChar(191)
  userId           String                 @map("user_id") @db.VarChar(191)
  kind             UploadKind
  objectKey        String                 @unique @map("object_key") @db.VarChar(255)
  publicUrl        String                 @map("public_url") @db.VarChar(512)
  mimeType         String                 @map("mime_type") @db.VarChar(64)
  sizeBytes        Int                    @map("size_bytes")
  width            Int
  height           Int
  validationStatus UploadValidationStatus @default(accepted) @map("validation_status")
  failureReason    String?                @map("failure_reason") @db.VarChar(255)
  createdAt        DateTime               @default(now()) @map("created_at")
  user             User                   @relation(fields: [userId], references: [id])

  @@map("image_uploads")
}

model ImageTask {
  id                   String                @id @default(cuid()) @db.VarChar(191)
  userId               String                @map("user_id") @db.VarChar(191)
  taskType             GenerationMode        @map("task_type")
  prompt               String                @db.Text
  negativePrompt       String?               @map("negative_prompt") @db.Text
  requestPayloadJson   Json                  @map("request_payload_json")
  provider             String                @db.VarChar(64)
  modelName            String                @map("model_name") @db.VarChar(120)
  state                ImageTaskState        @default(queued)
  priority             Int
  costCredits          Int                   @map("cost_credits")
  sourceAssetId        String?               @map("source_asset_id") @db.VarChar(191)
  creditHoldId         String?               @unique @map("credit_hold_id") @db.VarChar(191)
  queuedAt             DateTime              @default(now()) @map("queued_at")
  runningAt            DateTime?             @map("running_at")
  storingAt            DateTime?             @map("storing_at")
  reviewingAt          DateTime?             @map("reviewing_at")
  completedAt          DateTime?             @map("completed_at")
  failedAt             DateTime?             @map("failed_at")
  failureReason        String?               @map("failure_reason") @db.VarChar(255)
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  user                 User                  @relation(fields: [userId], references: [id])
  sourceAsset          ImageAsset?           @relation("SourceAssetTasks", fields: [sourceAssetId], references: [id])
  creditHold           CreditHold?           @relation("TaskActiveHold", fields: [creditHoldId], references: [id])
  submissions          ProviderSubmission[]
  assets               ImageAsset[]

  @@index([userId, state, priority])
  @@map("image_tasks")
}

model ProviderSubmission {
  id                 String         @id @default(cuid()) @db.VarChar(191)
  taskId             String         @map("task_id") @db.VarChar(191)
  provider           String         @db.VarChar(64)
  modelName          String         @map("model_name") @db.VarChar(120)
  providerMode       ProviderMode   @map("provider_mode")
  requestMetadataJson Json          @map("request_metadata_json")
  externalTaskId     String?        @map("external_task_id") @db.VarChar(191)
  createdAt          DateTime       @default(now()) @map("created_at")
  task               ImageTask      @relation(fields: [taskId], references: [id])
  results            ProviderResult[]

  @@map("provider_submissions")
}

model ProviderResult {
  id                String               @id @default(cuid()) @db.VarChar(191)
  submissionId      String               @map("submission_id") @db.VarChar(191)
  status            ProviderResultStatus
  rawPayloadDigest  String               @map("raw_payload_digest") @db.VarChar(128)
  outputMetadataJson Json?               @map("output_metadata_json")
  errorMetadataJson  Json?               @map("error_metadata_json")
  createdAt         DateTime             @default(now()) @map("created_at")
  submission        ProviderSubmission   @relation(fields: [submissionId], references: [id])

  @@map("provider_results")
}

model ImageAsset {
  id                              String             @id @default(cuid()) @db.VarChar(191)
  taskId                          String?            @map("task_id") @db.VarChar(191)
  userId                          String             @map("user_id") @db.VarChar(191)
  title                           String             @db.VarChar(160)
  taskType                        GenerationMode     @map("task_type")
  prompt                          String             @db.Text
  objectKey                       String             @unique @map("object_key") @db.VarChar(255)
  publicUrl                       String             @map("public_url") @db.VarChar(512)
  mimeType                        String             @map("mime_type") @db.VarChar(64)
  sizeBytes                       Int                @map("size_bytes")
  width                           Int
  height                          Int
  reviewStatus                    OutputReviewStatus @default(pending) @map("review_status")
  downloadState                   String             @default("not_downloaded") @map("download_state") @db.VarChar(32)
  modelProvider                   String             @map("model_provider") @db.VarChar(64)
  modelName                       String             @map("model_name") @db.VarChar(120)
  sourceAssetId                   String?            @map("source_asset_id") @db.VarChar(191)
  watermark                       Boolean            @default(true)
  hd                              Boolean            @default(false)
  entitlementSnapshotJson         Json?              @map("entitlement_snapshot_json")
  commercialAuthorizationStatement String?           @map("commercial_authorization_statement") @db.VarChar(512)
  deletedAt                       DateTime?          @map("deleted_at")
  createdAt                       DateTime           @default(now()) @map("created_at")
  updatedAt                       DateTime           @updatedAt @map("updated_at")
  task                            ImageTask?         @relation(fields: [taskId], references: [id])
  user                            User               @relation(fields: [userId], references: [id])
  sourceAsset                     ImageAsset?        @relation("AssetSource", fields: [sourceAssetId], references: [id])
  derivedAssets                   ImageAsset[]       @relation("AssetSource")
  sourceForTasks                  ImageTask[]        @relation("SourceAssetTasks")
  downloads                       DownloadEvent[]
  versionNodes                    AssetVersionNode[]

  @@index([userId, deletedAt, createdAt])
  @@map("image_assets")
}

model AssetVersionNode {
  id        String     @id @default(cuid()) @db.VarChar(191)
  label     String     @db.VarChar(160)
  assetId   String     @map("asset_id") @db.VarChar(191)
  createdAt DateTime   @default(now()) @map("created_at")
  asset     ImageAsset @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@map("asset_version_nodes")
}

model DownloadEvent {
  id                  String       @id @default(cuid()) @db.VarChar(191)
  assetId             String       @map("asset_id") @db.VarChar(191)
  userId              String       @map("user_id") @db.VarChar(191)
  downloadType        DownloadType @map("download_type")
  creditCost          Int          @map("credit_cost")
  proFairUseApplied   Boolean      @default(false) @map("pro_fair_use_applied")
  membershipCycleId   String?      @map("membership_cycle_id") @db.VarChar(191)
  createdAt           DateTime     @default(now()) @map("created_at")
  asset               ImageAsset   @relation(fields: [assetId], references: [id])
  user                User         @relation(fields: [userId], references: [id])
  creditHold          CreditHold? @relation("DownloadHoldTarget")

  @@index([userId, createdAt])
  @@map("download_events")
}

model AssetCleanupJob {
  id          String    @id @default(cuid()) @db.VarChar(191)
  assetId     String    @map("asset_id") @db.VarChar(191)
  objectKey   String    @map("object_key") @db.VarChar(255)
  reason      String    @db.VarChar(64)
  scheduledAt DateTime  @map("scheduled_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("asset_cleanup_jobs")
}
